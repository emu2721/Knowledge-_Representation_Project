<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/healthcare-clinical#"
     xml:base="http://www.semanticweb.org/healthcare-clinical"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:dcterms="http://purl.org/dc/terms/">

    <owl:Ontology rdf:about="http://www.semanticweb.org/healthcare-clinical">
        <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
        <rdfs:comment>A broad, robust OWL 2 ontology for clinical healthcare covering patients, professionals, diagnoses, treatments, facilities, and clinical events.</rdfs:comment>
        <rdfs:label>Healthcare Clinical Ontology</rdfs:label>
    </owl:Ontology>

    <!-- ====================== Object Properties ====================== -->
    <owl:ObjectProperty rdf:about="#hasDiagnosis">
        <rdfs:domain rdf:resource="#Patient"/>
        <rdfs:range rdf:resource="#Diagnosis"/>
        <owl:inverseOf rdf:resource="#isDiagnosisOf"/>
        <rdfs:label>hasDiagnosis</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#isDiagnosisOf">
        <rdfs:domain rdf:resource="#Diagnosis"/>
        <rdfs:range rdf:resource="#Patient"/>
        <rdfs:label>isDiagnosisOf</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasSymptom">
        <rdfs:domain rdf:resource="#Patient"/>
        <rdfs:range rdf:resource="#Symptom"/>
        <rdfs:label>hasSymptom</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#treatedBy">
        <rdfs:domain rdf:resource="#Patient"/>
        <rdfs:range rdf:resource="#HealthcareProfessional"/>
        <owl:inverseOf rdf:resource="#treats"/>
        <rdfs:label>treatedBy</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#treats">
        <rdfs:domain rdf:resource="#HealthcareProfessional"/>
        <rdfs:range rdf:resource="#Patient"/>
        <rdfs:label>treats</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#prescribes">
        <rdfs:domain rdf:resource="#Doctor"/>
        <rdfs:range rdf:resource="#Treatment"/>
        <rdfs:label>prescribes</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#performedIn">
        <rdfs:domain rdf:resource="#ClinicalEvent"/>
        <rdfs:range rdf:resource="#HealthcareFacility"/>
        <rdfs:label>performedIn</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#involvesPatient">
        <rdfs:domain rdf:resource="#ClinicalEvent"/>
        <rdfs:range rdf:resource="#Patient"/>
        <rdfs:label>involvesPatient</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasMedicalRecord">
        <rdfs:domain rdf:resource="#Patient"/>
        <rdfs:range rdf:resource="#MedicalRecord"/>
        <rdfs:label>hasMedicalRecord</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#hasSpecialty">
        <rdfs:domain rdf:resource="#HealthcareProfessional"/>
        <rdfs:range rdf:resource="#MedicalSpecialty"/>
        <rdfs:label>hasSpecialty</rdfs:label>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="#administers">
        <rdfs:domain rdf:resource="#Nurse"/>
        <rdfs:range rdf:resource="#Treatment"/>
        <rdfs:label>administers</rdfs:label>
    </owl:ObjectProperty>

    <!-- ====================== Data Properties ====================== -->
    <owl:DatatypeProperty rdf:about="#patientID">
        <rdfs:domain rdf:resource="#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>patientID</rdfs:label>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#age">
        <rdfs:domain rdf:resource="#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label>age</rdfs:label>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#gender">
        <rdfs:domain rdf:resource="#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>gender</rdfs:label>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#diagnosisDate">
        <rdfs:domain rdf:resource="#Diagnosis"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:label>diagnosisDate</rdfs:label>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#severity">
        <rdfs:domain rdf:resource="#Symptom"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>severity</rdfs:label>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#treatmentDescription">
        <rdfs:domain rdf:resource="#Treatment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>treatmentDescription</rdfs:label>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="#conditionStatus">
        <rdfs:domain rdf:resource="#Patient"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:label>conditionStatus</rdfs:label>
    </owl:DatatypeProperty>

    <!-- ====================== Classes ====================== -->
    <owl:Class rdf:about="#Person"><rdfs:label>Person</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Patient">
        <rdfs:subClassOf rdf:resource="#Person"/>
        <rdfs:comment>Person receiving healthcare services.</rdfs:comment>
        <rdfs:label>Patient</rdfs:label>
    </owl:Class>
    <owl:Class rdf:about="#HealthcareProfessional"><rdfs:subClassOf rdf:resource="#Person"/><rdfs:label>HealthcareProfessional</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Doctor"><rdfs:subClassOf rdf:resource="#HealthcareProfessional"/><rdfs:label>Doctor</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Nurse"><rdfs:subClassOf rdf:resource="#HealthcareProfessional"/><rdfs:label>Nurse</rdfs:label></owl:Class>

    <!-- Doctor Types -->
    <owl:Class rdf:about="#Surgeon"><rdfs:subClassOf rdf:resource="#Doctor"/><rdfs:label>Surgeon</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Cardiologist"><rdfs:subClassOf rdf:resource="#Doctor"/><rdfs:label>Cardiologist</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Endocrinologist"><rdfs:subClassOf rdf:resource="#Doctor"/><rdfs:label>Endocrinologist</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Oncologist"><rdfs:subClassOf rdf:resource="#Doctor"/><rdfs:label>Oncologist</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Pediatrician"><rdfs:subClassOf rdf:resource="#Doctor"/><rdfs:label>Pediatrician</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Neurologist"><rdfs:subClassOf rdf:resource="#Doctor"/><rdfs:label>Neurologist</rdfs:label></owl:Class>

    <owl:Class rdf:about="#Diagnosis"><rdfs:label>Diagnosis</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Symptom"><rdfs:label>Symptom</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Treatment"><rdfs:label>Treatment</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Medication"><rdfs:subClassOf rdf:resource="#Treatment"/><rdfs:label>Medication</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Surgery"><rdfs:subClassOf rdf:resource="#Treatment"/><rdfs:label>Surgery</rdfs:label></owl:Class>
    <owl:Class rdf:about="#ClinicalEvent"><rdfs:label>ClinicalEvent</rdfs:label></owl:Class>
    <owl:Class rdf:about="#MedicalRecord"><rdfs:label>MedicalRecord</rdfs:label></owl:Class>
    <owl:Class rdf:about="#HealthcareFacility"><rdfs:label>HealthcareFacility</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Hospital"><rdfs:subClassOf rdf:resource="#HealthcareFacility"/><rdfs:label>Hospital</rdfs:label></owl:Class>
    <owl:Class rdf:about="#Clinic"><rdfs:subClassOf rdf:resource="#HealthcareFacility"/><rdfs:label>Clinic</rdfs:label></owl:Class>
    <owl:Class rdf:about="#MedicalSpecialty"><rdfs:label>MedicalSpecialty</rdfs:label></owl:Class>

    <!-- ====================== Individuals ====================== -->
    <!-- Patients -->
    <owl:NamedIndividual rdf:about="#JohnDoe">
        <rdf:type rdf:resource="#Patient"/>
        <patientID>PT-987654</patientID>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">54</age>
        <gender>Male</gender>
        <conditionStatus>Stable</conditionStatus>
        <hasDiagnosis rdf:resource="#Type2Diabetes"/>
        <treatedBy rdf:resource="#DrAliceSmith"/>
        <rdfs:label>John Doe</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#EmmaWilson">
        <rdf:type rdf:resource="#Patient"/>
        <patientID>PT-112233</patientID>
        <age rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">8</age>
        <gender>Female</gender>
        <conditionStatus>Recovering</conditionStatus>
        <treatedBy rdf:resource="#DrSophiaRodriguez"/>
        <rdfs:label>Emma Wilson</rdfs:label>
    </owl:NamedIndividual>

    <!-- Doctors - One for each type -->
    <owl:NamedIndividual rdf:about="#DrAliceSmith">
        <rdf:type rdf:resource="#Endocrinologist"/>
        <hasSpecialty rdf:resource="#Endocrinology"/>
        <rdfs:label>Dr. Alice Smith</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#DrMichaelBrown">
        <rdf:type rdf:resource="#Oncologist"/>
        <hasSpecialty rdf:resource="#Oncology"/>
        <rdfs:label>Dr. Michael Brown</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#DrSarahChen">
        <rdf:type rdf:resource="#Cardiologist"/>
        <hasSpecialty rdf:resource="#Cardiology"/>
        <rdfs:label>Dr. Sarah Chen</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#DrJamesPatel">
        <rdf:type rdf:resource="#Neurologist"/>
        <hasSpecialty rdf:resource="#Neurology"/>
        <rdfs:label>Dr. James Patel</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#DrSophiaRodriguez">
        <rdf:type rdf:resource="#Pediatrician"/>
        <hasSpecialty rdf:resource="#Pediatrics"/>
        <rdfs:label>Dr. Sophia Rodriguez</rdfs:label>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#DrRobertKim">
        <rdf:type rdf:resource="#Surgeon"/>
        <hasSpecialty rdf:resource="#GeneralSurgery"/>
        <rdfs:label>Dr. Robert Kim</rdfs:label>
    </owl:NamedIndividual>

    <!-- Supporting Individuals -->
    <owl:NamedIndividual rdf:about="#Type2Diabetes"><rdf:type rdf:resource="#Diagnosis"/><rdfs:label>Type 2 Diabetes Mellitus</rdfs:label></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Endocrinology"><rdf:type rdf:resource="#MedicalSpecialty"/><rdfs:label>Endocrinology</rdfs:label></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Oncology"><rdf:type rdf:resource="#MedicalSpecialty"/><rdfs:label>Oncology</rdfs:label></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Cardiology"><rdf:type rdf:resource="#MedicalSpecialty"/><rdfs:label>Cardiology</rdfs:label></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Neurology"><rdf:type rdf:resource="#MedicalSpecialty"/><rdfs:label>Neurology</rdfs:label></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#Pediatrics"><rdf:type rdf:resource="#MedicalSpecialty"/><rdfs:label>Pediatrics</rdfs:label></owl:NamedIndividual>
    <owl:NamedIndividual rdf:about="#GeneralSurgery"><rdf:type rdf:resource="#MedicalSpecialty"/><rdfs:label>General Surgery</rdfs:label></owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#CentralHospital">
        <rdf:type rdf:resource="#Hospital"/>
        <rdfs:label>Central Hospital</rdfs:label>
    </owl:NamedIndividual>

</rdf:RDF>